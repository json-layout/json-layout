{
  "name": "@json-layout/agents",
  "version": "0.1.0",
  "type": "module",
  "description": "AI agent tools for JSON Layout - programmatic API and MCP server",
  "license": "MIT",
  "main": "src/index.ts",
  "bin": {
    "json-layout-mcp": "src/mcp/server.ts"
  },
  "exports": {
    ".": "./src/index.ts",
    "./mcp": "./src/mcp/server.ts",
    "./tools": "./src/tools/index.ts"
  },
  "scripts": {
    "test": "node --test test/*.spec.ts",
    "test:only": "node --test --test-only test/*.spec.ts",
    "watch:test": "node --test --watch test/*.spec.ts",
    "build": "tsc --noEmit"
  },
  "peerDependencies": {
    "@json-layout/core": "^2.4.0",
    "@json-layout/vocabulary": "^2.12.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.0",
    "ai": "^6.0.116",
    "debug": "^4.3.4",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/debug": "^4.1.12",
    "typescript": "^5.2.2"
  }
}
